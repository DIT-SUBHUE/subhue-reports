# ── Manifest API ──────────────────────────────────────────────────────────────
DBT_MANIFEST_API_BASE_URL=https://diid.subhue.org
DBT_MANIFEST_API_USERNAME=dbt_manifest
DBT_MANIFEST_API_PASSWORD=senha-segura
DBT_MANIFEST_TAG=airflow_astro

# alternativa: path local para dev (skip API)
# DBT_MANIFEST_PATH=data/manifest/manifest.json

# ── Dados Documentações API ───────────────────────────────────────────────────
DADOS_DOCS_API_BASE_URL=https://diid.subhue.org
DADOS_DOCS_API_USERNAME=dbt_docs
DADOS_DOCS_API_PASSWORD=senha-segura

# ── Banco de dados (perfil dbt) ───────────────────────────────────────────────
DBT_IP=host-do-banco
DBT_PGPORT=6432
DBT_DATABASE_NAME=subhue
DBT_USER=dbt_transform
DBT_SENHA=senha

# ── Banco de dados (perfil subhue) ────────────────────────────────────────────
SUBHUE_IP=host-do-banco
SUBHUE_PGPORT=6432
SUBHUE_DATABASE_NAME=subhue
SUBHUE_USER=subhue-engenharia-dev
SUBHUE_SENHA=senha
